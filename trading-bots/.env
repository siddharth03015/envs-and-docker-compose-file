# Trading Bots — Environment Configuration
# Copy this file to .env and edit as needed.
# Values here are overridden by real environment variables if both are set.

# Exchange engine base URL
ENGINE_URL=http://localhost:8080

# Shared password used when registering / logging in all bot accounts
BOT_PASSWORD=bot-secret-2026

# Port for the metrics HTTP server
METRICS_PORT=9090
